# Copy to .env for local dev (Expo loads EXPO_PUBLIC_* at bundle time)

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Cloud → OAuth 2.0 client → Authorized redirect URIs (same project as EXPO_PUBLIC_SUPABASE_URL), e.g.:
# https://ylcyktbppowabnxuwdrr.supabase.co/auth/v1/callback
#
# Apple “Sign in with Apple” (Services ID, e.g. com.pixgo.pixgo.appleauth):
# • Return URL (Apple Developer → Services ID → Web): MUST be exactly:
#   https://ylcyktbppowabnxuwdrr.supabase.co/auth/v1/callback
# • That URL is Supabase’s server (GoTrue); the app never opens it directly.
#   After Apple → Supabase, the user is redirected to the in-app URL from
#   getOAuthRedirectUri() (e.g. pixapp://~oauth/callback); list that exact URL
#   under Supabase → Authentication → URL Configuration → Redirect URLs.

# HTTPS origin for email confirm / password reset (NOT the in-app OAuth return URL)
EXPO_PUBLIC_OAUTH_REDIRECT_BASE=https://pixapp.kz

# Optional: force native OAuth redirect (default = app scheme + /~oauth/callback from Expo Linking)
# EXPO_PUBLIC_OAUTH_MOBILE_REDIRECT_URI=pixapp://~oauth/callback

# Deep link scheme for Stripe return (must match app.config.ts `scheme`)
EXPO_PUBLIC_STRIPE_RETURN_SCHEME=pixapp

# Optional: EAS project ID for push (expo-notifications)
# EXPO_PUBLIC_EAS_PROJECT_ID=

# In-app maps + directions (Google Cloud: enable Maps SDK Android/iOS, Directions API, Geocoding API)
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
